# Configuração da base de dados PostgreSQL
# Copia este ficheiro para .env e preenche com as tuas credenciais

# Format: postgresql://user:password@localhost:5432/database_name
# Local (sem Docker): use localhost
# Com docker-compose: use 'postgres' (nome do serviço) em vez de localhost
DATABASE_URL=postgresql://helpdesk_user:helpdesk_password@localhost:5432/helpdesk_db

# Credenciais usadas pelo docker-compose para criar o container do postgres
POSTGRES_USER=helpdesk_user
POSTGRES_PASSWORD=helpdesk_password
POSTGRES_DB=helpdesk_db

# Ambiente (development, production, testing)
ENVIRONMENT=development

# Logging
LOG_LEVEL=info

# 👈 JWT Secrets Management
SECRET_KEY=<aqui vai o secret key>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 👈 CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000